# Copie para .env (local) ou configure no painel do Render.

# String de conexão do Postgres (Neon). Quando presente, ativa a
# contagem global durável. Sem ela, a app usa persistência em arquivo.
# Ex.: postgresql://user:pass@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Porta (o Render define automaticamente; localmente o padrão é 3000)
# PORT=3000

# Dificuldade da prova-de-trabalho (nº de zeros no início do hash)
CHAIN_DIFFICULTY=3

# Integração com a API do TSE (true/false)
TSE_ENABLED=true

# Opcional: diretório de dados gravável (ex.: volume). Só usado no modo arquivo.
# DATA_DIR=/var/data
